{
  "name": "@grimoire/talisman",
  "version": "0.0.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grimoire/rune": "workspace:*",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@xmldom/xmldom": "^0.9.10",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist"
  ]
}
